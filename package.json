{
  "name": "f9g",
  "version": "0.0.1",
  "description": "Feature flag library that magically can make the feature turn invisible and visible with only cast a spell in runtime",
  "main": "index.js",
  "author": "Mirza Adipradhana <madipradhana@gmail.com>",
  "scripts": {
    "build": "turbo run build",
    "build:core": "turbo run build --scope=@f9g/core",
    "build:adapter-firebase": "turbo run build --scope=@f9g/adapter-firebase-rn",
    "build:adapter-firebase-web": "turbo run build --scope=@f9g/adapter-firebase-rn",
    "build:react": "turbo run build --scope=@f9g/react",
    "dev": "npx concurrently yarn:dev:*",
    "dev:core": "yarn --cwd packages/core dev",
    "dev:adapter-firebase": "yarn --cwd packages/adapters/firebase-rn dev",
    "dev:adapter-firebase-web": "yarn --cwd packages/adapters/firebase-web dev",
    "dev:react": "yarn --cwd packages/react dev",
    "dev:example": "yarn --cwd example dev",
    "semantic-release": "multi-semantic-release",
    "release": "yarn build && yarn semantic-release"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^5.0.1",
    "@semantic-release/commit-analyzer": "8.0.1",
    "@semantic-release/git": "^9.0.0",
    "@semantic-release/gitlab": "^6.1.0",
    "@semantic-release/npm": "^7.1.3",
    "@semantic-release/release-notes-generator": "^9.0.2",
    "concurrently": "^6.2.0",
    "dotenv": "^8.2.0",
    "multi-semantic-release": "^2.11.0",
    "node-fetch": "^3.3.2",
    "semantic-release-monorepo": "^7.0.5",
    "turbo": "^1.13.2"
  },
  "resolutions": {
    "@types/react": "16.8"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/adapters/*"
    ]
  },
  "license": "MIT",
  "private": true
}
